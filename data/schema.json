{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CarromAchievements",
  "type": "object",
  "required": ["lastUpdated", "players", "slams"],
  "additionalProperties": false,
  "properties": {
    "lastUpdated": {
      "type": "string",
      "format": "date"
    },
    "players": {
      "type": "array",
      "items": { "$ref": "#/$defs/player" }
    },
    "slams": {
      "type": "array",
      "items": { "$ref": "#/$defs/slam" }
    }
  },
  "$defs": {
    "player": {
      "type": "object",
      "required": ["id", "name", "displayOrder"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "displayOrder": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "slam": {
      "type": "object",
      "required": ["id", "playerId", "slamType", "format", "tournament", "date"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^slam-[0-9]+$"
        },
        "playerId": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "slamType": {
          "type": "string",
          "enum": ["white", "black"]
        },
        "format": {
          "type": "string",
          "enum": ["singles", "doubles"]
        },
        "tournament": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}

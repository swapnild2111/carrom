{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CarromTotalSlams",
  "type": "object",
  "required": ["year", "lastUpdated", "summary", "players"],
  "additionalProperties": false,
  "properties": {
    "year": {
      "type": "integer",
      "minimum": 2000
    },
    "lastUpdated": {
      "type": "string",
      "format": "date"
    },
    "summary": {
      "type": "object",
      "required": ["club", "state", "totals"],
      "additionalProperties": false,
      "properties": {
        "club": { "$ref": "#/$defs/slamPair" },
        "state": { "$ref": "#/$defs/slamPair" },
        "totals": {
          "type": "object",
          "required": ["white", "black", "all"],
          "additionalProperties": false,
          "properties": {
            "white": { "type": "integer", "minimum": 0 },
            "black": { "type": "integer", "minimum": 0 },
            "all": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "players": {
      "type": "array",
      "items": { "$ref": "#/$defs/player" }
    }
  },
  "$defs": {
    "slamPair": {
      "type": "object",
      "required": ["white", "black"],
      "additionalProperties": false,
      "properties": {
        "white": { "type": "integer", "minimum": 0 },
        "black": { "type": "integer", "minimum": 0 }
      }
    },
    "player": {
      "type": "object",
      "required": ["id", "name", "club", "displayOrder", "slams", "totals"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "club": {
          "type": ["string", "null"]
        },
        "displayOrder": {
          "type": "integer",
          "minimum": 1
        },
        "slams": {
          "type": "object",
          "required": ["club", "state"],
          "additionalProperties": false,
          "properties": {
            "club": { "$ref": "#/$defs/slamPair" },
            "state": { "$ref": "#/$defs/slamPair" }
          }
        },
        "totals": {
          "type": "object",
          "required": ["white", "black", "all"],
          "additionalProperties": false,
          "properties": {
            "white": { "type": "integer", "minimum": 0 },
            "black": { "type": "integer", "minimum": 0 },
            "all": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}

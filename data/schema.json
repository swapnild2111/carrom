{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CarromAchievements",
  "type": "object",
  "required": ["year", "lastUpdated", "players", "tournaments", "slamMatrix", "slamEvents"],
  "additionalProperties": false,
  "properties": {
    "year": {
      "type": "integer",
      "minimum": 2000
    },
    "lastUpdated": {
      "type": "string",
      "format": "date"
    },
    "players": {
      "type": "array",
      "items": { "$ref": "#/$defs/player" }
    },
    "tournaments": {
      "type": "array",
      "items": { "$ref": "#/$defs/tournament" }
    },
    "slamMatrix": {
      "type": "object",
      "required": ["white", "black"],
      "additionalProperties": false,
      "properties": {
        "white": {
          "type": "array",
          "items": { "$ref": "#/$defs/matrixRow" }
        },
        "black": {
          "type": "array",
          "items": { "$ref": "#/$defs/matrixRow" }
        }
      }
    },
    "slamEvents": {
      "type": "array",
      "items": { "$ref": "#/$defs/slamEvent" }
    }
  },
  "$defs": {
    "player": {
      "type": "object",
      "required": ["id", "name", "gender", "district", "displayOrder", "totals"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "gender": {
          "type": "string",
          "enum": ["male", "female"]
        },
        "district": {
          "type": "string",
          "minLength": 1
        },
        "displayOrder": {
          "type": "integer",
          "minimum": 1
        },
        "totals": {
          "type": "object",
          "required": ["white", "black"],
          "additionalProperties": false,
          "properties": {
            "white": { "type": "integer", "minimum": 0 },
            "black": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "tournament": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "matrixRow": {
      "type": "object",
      "required": ["playerId", "counts"],
      "additionalProperties": false,
      "properties": {
        "playerId": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "matchDetail": {
      "type": "object",
      "required": ["number", "set", "board"],
      "additionalProperties": false,
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "set": { "type": "integer", "minimum": 1 },
        "board": { "type": "integer", "minimum": 1 }
      }
    },
    "slamEvent": {
      "type": "object",
      "required": ["id", "playerId", "slamType", "district"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^evt-[0-9]+$"
        },
        "playerId": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "slamType": {
          "type": "string",
          "enum": ["white", "black"]
        },
        "tournamentId": {
          "type": ["string", "null"],
          "pattern": "^[a-z0-9-]+$"
        },
        "district": {
          "type": "string",
          "minLength": 1
        },
        "match": {
          "oneOf": [
            { "$ref": "#/$defs/matchDetail" },
            { "type": "null" }
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StateCircuitSlams",
  "type": "object",
  "required": ["year", "lastUpdated", "summary", "tournaments", "districts", "players"],
  "properties": {
    "year": { "type": "integer" },
    "lastUpdated": { "type": "string", "format": "date" },
    "summary": { "type": "object" },
    "tournaments": { "type": "array" },
    "districts": { "type": "array" },
    "players": { "type": "array" }
  }
}
